{
  "name": "code-agent",
  "version": "1.0.0",
  "description": "Claude Code CLI - Leaked source analysis",
  "type": "module",
  "main": "dist-electron/main.js",
  "cli-main": "dist/main.js",
  "bin": {
    "code-agent": "dist/main.js"
  },
  "scripts": {
    "setup": "node setup.js",
    "build": "node run-build.js",
    "build:watch": "tsc --watch",
    "dev": "tsx watch src/main.tsx",
    "clean": "del /s /q dist 2>nul || rm -rf dist",
    "build:renderer": "node build-renderer.mjs",
    "build:electron:main": "tsc -p tsconfig.electron.json && node write-electron-package.mjs",
    "build:electron": "npm run build:electron:main && tsc -p tsconfig.renderer.json --noEmit && npm run build:renderer",
    "build:electron:prod": "cross-env NODE_ENV=production npm run build:electron:main && tsc -p tsconfig.renderer.json --noEmit && npm run build:renderer",
    "dev:electron": "npm run build:electron && cross-env NODE_ENV=development electron .",
    "dev:electron:watch": "concurrently \"tsc -p tsconfig.electron.json -w\" \"tsc -p tsconfig.renderer.json -w\" \"wait-on dist-electron/main.js && electron .\"",
    "dist": "npm run build:electron:prod && electron-builder",
    "dist:win": "npm run build:electron:prod && electron-builder --win",
    "dist:mac": "npm run build:electron:prod && electron-builder --mac",
    "dist:linux": "npm run build:electron:prod && electron-builder --linux",
    "pack": "electron-builder --dir --publish never"
  },
  "keywords": [
    "claude",
    "code",
    "cli",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.3",
    "@anthropic-ai/sdk": "^0.24.0",
    "@commander-js/extra-typings": "^11.1.0",
    "@growthbook/growthbook": "^1.6.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/api-logs": "^0.57.2",
    "@opentelemetry/core": "^1.30.1",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.57.2",
    "@opentelemetry/exporter-logs-otlp-http": "^0.57.2",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.57.2",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.57.2",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.2",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.57.2",
    "@opentelemetry/exporter-prometheus": "^0.57.2",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.2",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-logs": "^0.57.2",
    "@opentelemetry/sdk-metrics": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.3.7",
    "ajv": "^8.17.1",
    "asciichart": "^1.5.25",
    "auto-bind": "^5.0.1",
    "axios": "^1.7.0",
    "bidi-js": "^1.0.3",
    "cacache": "^20.0.1",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "cli-boxes": "^3.0.0",
    "cli-highlight": "^2.1.11",
    "code-excerpt": "^4.0.0",
    "commander": "^11.1.0",
    "diff": "^5.1.0",
    "emoji-regex": "^10.4.0",
    "env-paths": "^3.0.0",
    "execa": "^9.5.2",
    "fflate": "^0.8.2",
    "figures": "^6.0.0",
    "fuse.js": "^7.1.0",
    "get-east-asian-width": "^1.3.1",
    "google-auth-library": "^9.15.1",
    "highlight.js": "^11.11.1",
    "https-proxy-agent": "^7.0.6",
    "ignore": "^7.0.5",
    "indent-string": "^5.0.0",
    "ink": "^4.4.1",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.17.21",
    "lru-cache": "^11.2.2",
    "marked": "^15.0.12",
    "p-map": "^5.5.0",
    "picomatch": "^4.0.2",
    "plist": "^3.1.0",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.3.1",
    "react-reconciler": "^0.29.2",
    "semver": "^7.5.4",
    "sharp": "^0.34.2",
    "shell-quote": "^1.8.2",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.1.0",
    "supports-hyperlinks": "^4.1.0",
    "tree-kill": "^1.2.2",
    "trim": "^1.0.1",
    "turndown": "^7.2.0",
    "typescript": "^5.3.0",
    "undici": "^7.13.0",
    "usehooks-ts": "^3.1.1",
    "vscode-jsonrpc": "^8.2.1",
    "wrap-ansi": "^8.1.0",
    "ws": "^8.15.0",
    "xss": "^1.0.15",
    "yaml": "^2.8.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.0",
    "@types/electron": "^1.6.10",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.0",
    "esbuild": "^0.27.7",
    "keytar": "^7.9.0",
    "tsx": "^4.7.0",
    "wait-on": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.anthropic.code-agent",
    "productName": "Code Agent",
    "directories": {
      "buildResources": "electron/resources",
      "output": "dist-build"
    },
    "files": [
      "dist-electron/**",
      "dist-renderer/**",
      "node_modules/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "dmg": {
      "sign": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
