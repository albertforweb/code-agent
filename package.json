{
  "name": "code-agent",
  "version": "1.0.0",
  "description": "CodeAgent local-first coding agent",
  "type": "module",
  "main": "dist/entrypoints/cli.js",
  "cli-main": "dist/entrypoints/cli.js",
  "bin": {
    "code-agent": "dist/entrypoints/cli.js"
  },
  "files": [
    "dist",
    "docs/macos-cli-distribution.md",
    "README.md"
  ],
  "scripts": {
    "setup": "node setup.js",
    "build": "node run-build.js",
    "build:watch": "tsc --watch",
    "dev": "npm run build && node dist/entrypoints/cli.js",
    "code-agent": "node dist/entrypoints/cli.js",
    "codeagent": "node dist/entrypoints/cli.js",
    "clean": "del /s /q dist 2>nul || rm -rf dist",
    "build:renderer": "node build-renderer.mjs",
    "build:electron:main": "tsc -p tsconfig.electron.json && node write-electron-package.mjs",
    "build:electron": "npm run build:electron:main && tsc -p tsconfig.renderer.json --noEmit && npm run build:renderer",
    "build:electron:prod": "cross-env NODE_ENV=production npm run build:electron",
    "generate:brand-assets": "node scripts/generate-brand-assets.mjs",
    "dev:electron": "npm run build:electron && cross-env NODE_ENV=development electron dist-electron",
    "dev:electron:debug": "npm run build:electron && cross-env NODE_ENV=development ELECTRON_OPEN_DEVTOOLS=1 electron dist-electron",
    "dev:electron:gpu-off": "npm run build:electron && cross-env NODE_ENV=development ELECTRON_DISABLE_GPU=1 electron dist-electron",
    "dev:electron:watch": "concurrently \"tsc -p tsconfig.electron.json -w\" \"tsc -p tsconfig.renderer.json -w\" \"wait-on dist-electron/main.js && electron dist-electron\"",
    "dist": "npm run generate:brand-assets && npm run build:electron:prod && electron-builder",
    "dist:win": "npm run generate:brand-assets && npm run build:electron:prod && electron-builder --win",
    "dist:mac": "npm run generate:brand-assets && npm run build:electron:prod && electron-builder --mac",
    "dist:linux": "npm run generate:brand-assets && npm run build:electron:prod && electron-builder --linux",
    "pack": "npm run generate:brand-assets && npm run build:electron:prod && electron-builder --dir --publish never",
    "pack:desktop:check": "npm run pack && npm run verify:desktop-package",
    "verify:desktop-package": "node scripts/verify-desktop-package.mjs",
    "verify:desktop-release": "node scripts/verify-desktop-package.mjs --release",
    "pack:cli": "npm run build && node scripts/pack-cli.mjs",
    "pack:cli:check": "npm run build && node scripts/pack-cli.mjs && npm run verify:cli-package",
    "verify:cli-package": "node scripts/verify-cli-package.mjs",
    "build:ios-companion": "node scripts/verify-ios-companion.mjs",
    "verify:ios-companion": "node scripts/verify-ios-companion.mjs",
    "verify:remote-control-scope": "node scripts/verify-remote-control-scope.mjs",
    "verify:remote-control-smoke": "tsx scripts/verify-remote-control-smoke.ts",
    "verify:phase5": "node scripts/verify-phase5.mjs",
    "pack:phase5": "npm run pack:cli && npm run pack && npm run release:notes && npm run verify:phase5",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "release": "npm run generate:brand-assets && npm run build:electron:prod && electron-builder --publish always"
  },
  "keywords": [
    "code-agent",
    "agent",
    "local-llm",
    "openai-compatible",
    "cli",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.3",
    "@commander-js/extra-typings": "^11.1.0",
    "@growthbook/growthbook": "^1.6.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/api-logs": "^0.57.2",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.219.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.219.0",
    "@opentelemetry/exporter-prometheus": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.3.7",
    "ajv": "^8.17.1",
    "asciichart": "^1.5.25",
    "auto-bind": "^5.0.1",
    "axios": "^1.7.0",
    "bidi-js": "^1.0.3",
    "cacache": "^20.0.1",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "cli-boxes": "^3.0.0",
    "cli-highlight": "^2.1.11",
    "code-excerpt": "^4.0.0",
    "commander": "^11.1.0",
    "diff": "^5.1.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.0",
    "emoji-regex": "^10.4.0",
    "env-paths": "^3.0.0",
    "execa": "^9.5.2",
    "fflate": "^0.8.2",
    "figures": "^6.0.0",
    "fuse.js": "^7.1.0",
    "get-east-asian-width": "^1.3.1",
    "google-auth-library": "^9.15.1",
    "highlight.js": "^11.11.1",
    "https-proxy-agent": "^7.0.6",
    "ignore": "^7.0.5",
    "indent-string": "^5.0.0",
    "ink": "^4.4.1",
    "jsonc-parser": "^3.3.1",
    "keytar": "^7.9.0",
    "lodash-es": "^4.17.21",
    "lru-cache": "^11.2.2",
    "marked": "^15.0.12",
    "p-map": "^5.5.0",
    "picomatch": "^4.0.2",
    "plist": "^3.1.0",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.3.1",
    "react-reconciler": "^0.29.2",
    "semver": "^7.5.4",
    "sharp": "^0.34.2",
    "shell-quote": "^1.8.2",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.1.0",
    "supports-hyperlinks": "^4.1.0",
    "tree-kill": "^1.2.2",
    "trim": "^1.0.1",
    "turndown": "^7.2.0",
    "typescript": "^5.3.0",
    "undici": "^7.13.0",
    "usehooks-ts": "^3.1.1",
    "vscode-jsonrpc": "^8.2.1",
    "wrap-ansi": "^8.1.0",
    "ws": "^8.15.0",
    "xss": "^1.0.15",
    "yaml": "^2.8.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.0",
    "@types/electron": "^1.6.10",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.7.0",
    "wait-on": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.albertforweb.codeagent",
    "productName": "CodeAgent",
    "directories": {
      "buildResources": "electron/resources",
      "output": "dist-build"
    },
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "afterSign": "electron/notarize.cjs",
    "publish": [
      {
        "provider": "github",
        "owner": "albertforweb",
        "repo": "code-agent",
        "releaseType": "release"
      }
    ],
    "detectUpdateChannel": true,
    "generateUpdatesFilesForAllChannels": true,
    "files": [
      "dist-electron/**",
      "dist-renderer/**",
      "electron/resources/icon.png",
      "electron/resources/icon.ico",
      "node_modules/**"
    ],
    "win": {
      "icon": "electron/resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
    ]
  },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "icon": "electron/resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "dmg": {
      "sign": false
    },
    "linux": {
      "icon": "electron/resources/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
